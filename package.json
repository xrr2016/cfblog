{
  "name": "cfblog",
  "private": true,
  "scripts": {
    "fmt": "oxfmt",
    "build": "turbo run build",
    "build:server": "turbo run build --filter @cfblog/server",
    "dev": "turbo run dev",
    "dev:blog": "turbo run dev --filter @cfblog/blog",
    "dev:admin": "turbo run dev --filter @cfblog/admin",
    "dev:server": "turbo run dev --filter @cfblog/server",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "dryrun:staging": "pnpm run build:server &&  wrangler deploy --dry-run --env staging",
    "dryrun:production": "wrangler deploy --dry-run --env production"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0"
}
