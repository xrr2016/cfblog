{
  "name": "cfblog",
  "private": true,
  "scripts": {
    "fmt": "oxfmt",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter @cfblog/api",
    "dev:blog": "turbo run dev --filter @cfblog/blog",
    "dev:admin": "turbo run dev --filter @cfblog/admin",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0"
}
